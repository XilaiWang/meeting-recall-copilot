# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
*.tsbuildinfo
# Why: apps/desktop/build/ holds electron-builder config (entitlements, icons),
# not build artefacts — negate the blanket build/ exclusion for this path.
!apps/desktop/build/
!apps/desktop/build/**

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test
coverage/
*.lcov

# Electron
apps/desktop/release/
apps/desktop/out/
*.dmg

# Swift compiled binaries — generated by "pnpm build:swift", not stored in git
apps/desktop/resources/QAMatchingOverlay
apps/desktop/resources/SpeechHelper
*.exe
*.AppImage

# CoreML speaker-gate model — converted offline via scripts/convert-campplus-coreml.py,
# bundled at pack time via build.extraResources; the 14 MB artifact is not stored in git.
apps/desktop/resources/CAMPlusSpeaker.mlmodelc/
apps/desktop/resources/CAMPlusSpeaker.mlpackage/

# e5 embedding model (Xenova/multilingual-e5-small) — 465 MB, cached at first dev run
# under userData/transformers-cache, copied to resources/models/ for offline packaging.
# Not stored in git.
apps/desktop/resources/models/

# Database
*.db
*.db-journal
*.sqlite


# Python (offline model-conversion tooling under apps/desktop/scripts)
__pycache__/
*.pyc

# Misc
.turbo/
.cache/
# Planning doc symlinks — machine-specific, clone to restore
docs/01-Discovery
docs/02-Definition
docs/02-Discovery
docs/03-Architecture
docs/04-Implementation
