# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://qauser:qapass@localhost:5432/qa_matching

# JWT secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=PLACEHOLDER_REPLACE_WITH_RANDOM_256BIT
JWT_REFRESH_SECRET=PLACEHOLDER_REPLACE_WITH_DIFFERENT_256BIT

# Rate limiting — OPTIONAL. Unset = per-instance in-memory limiter (fine for a
# single machine). Set BOTH to make rate limits GLOBAL across instances (required
# before horizontal scaling / multi-machine). Create an Upstash Redis DB and copy
# its REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# LLM (for cold start proxy, ADR-12)
ANTHROPIC_API_KEY=

# Email (Resend, optional for Week 1)
RESEND_API_KEY=
